# Next.js exposes only variables prefixed with NEXT_PUBLIC_ to browser code.
# Do not use VITE_SUPABASE_URL or VITE_SUPABASE_ANON_KEY in this project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Keep this server-only. Never import or expose it in client components.
SUPABASE_SERVICE_ROLE_KEY=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
